# Copy to .env and fill in. forgeducation reads keys from the environment or this file.

# Cloud backend (default). Required when a pipeline uses provider: openai.
OPENAI_API_KEY=

# Optional tracing backend. When set, every LLM-backed agent prompt is recorded
# to Langfuse under one trace per pipeline run.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Local backend (optional). Used when a pipeline/stage uses provider: ollama.
# Start a local server with `ollama serve`; default endpoint shown below.
OLLAMA_BASE_URL=http://localhost:11434/v1
